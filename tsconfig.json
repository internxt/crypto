{
  "compilerOptions": {
    "target": "ESNext",
    "module": "nodenext",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "rootDir": "./src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "nodenext",
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo" 
  },
  "include": ["src"]
}
